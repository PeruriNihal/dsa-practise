#include <iostream>
using namespace std;

int BinaryToDec(int binarynum){
    int pow = 1;
    int ans = 0;
    while(binarynum>0){
        int rem = binarynum % 10;
        ans += (rem * pow);
        binarynum /= 10;
        pow *= 2;  
    }
    return ans;
}
int main(){
    int n;
    cout << "enter number: ";
    cin >> n;
    BinaryToDec(n);
cout << "decimal number = " << BinaryToDec(n) << endl;
}
