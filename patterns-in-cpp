// prints a rectangle of numbers
int main (){
  int n;
  cout << "enter number: ";
  cin >> n;
  for(int i = 1; i<=n; i++){
      for(int j = 1; j<=n; j++){
          cout << j << " ";

      }
      cout << endl;
  }
  return 0;
}

// prints a rectangle of numbers in reverse order
int main (){
  int n;
  cout << "enter number: ";
  cin >> n;
  for(int i = 1; i<=n; i++){
      for(int j = n; j>=1; j--){
          cout << j << " ";    
      }
      cout << endl;
  }
  return 0;
}

