//prints a upside down triangle of stars
int main(){     
  int n;
  cout << "enter number: ";
  cin >> n;
  for(int i=0; i<n; i++){
    for(int j=n-i; j>0; j--){
      cout << "*";
    }
    cout << endl;
  }
  return 0;
}

