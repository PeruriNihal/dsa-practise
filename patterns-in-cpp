#include<iostream>
using namespace std;
// prints a square of stars
int main (){ 
  int m;
  cout << "enter number of columns: ";
  cin >> m;
  for (int i=1; i<=m; i++){ 
      for (int j=0; j<m; j++){
      cout << "*";
      }
      cout << endl;     
    }
}

// prints a rectangle of numbers
int main (){
  int n;
  cout << "enter number: ";
  cin >> n;
  for(int i = 1; i<=n; i++){
      for(int j = 1; j<=n; j++){
          cout << j;

      }
      cout << endl;
  }
  return 0;
}

// prints a rectangle of numbers in reverse order
int main (){
  int n;
  cout << "enter number: ";
  cin >> n;
  for(int i = 1; i<=n; i++){
      for(int j = n; j>=1; j--){
          cout << j;    
      }
      cout << endl;
  }
  return 0;
}

