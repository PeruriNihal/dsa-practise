#include <iostream>
using namespace std;

int DecToBinary(int n){
    int ans = 0;
    int Pow = 1;
    while(n>0){
        int rem = n%2;
        n/=2;
        
        ans += (rem * Pow);
        Pow *= 10;
    }
    return ans;
}

int main(){
    int n;
    cout << "enter decimal number: ";
    cin >> n;
    
    // FIX: Catch and print the returned value here
    cout << "Binary form: " << DecToBinary(n) << endl; 
    
    return 0;
}
